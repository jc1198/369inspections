---
/**
 * TrustBar — four credibility points with icons.
 * Desktop: one row of 4. Mobile: 2x2 grid.
 */
const items = [
  {
    label: 'Veteran-owned',
    // military service medal
    icon: '<path d="M7.21 15 2.66 7.14a2 2 0 0 1 .13-2.2L4.4 2.8A2 2 0 0 1 6 2h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15"/><path d="M11 12 5.43 2.31"/><path d="m13 12 5.57-9.69"/><path d="M8 7h8"/><circle cx="12" cy="17" r="5"/><path d="M12 18v-2h-.5"/>',
  },
  {
    label: '10+ years construction experience',
    // hard hat
    icon: '<path d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1z"/><path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M4 15v-3a6 6 0 0 1 6-6"/><path d="M14 6a6 6 0 0 1 6 6v3"/>',
  },
  {
    label: 'InterNACHI certified',
    // verified badge
    icon: '<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>',
  },
  {
    label: '5% donated to Humanity Relief',
    // hands holding a heart
    icon: '<path d="M12 9 11 8a2 2 0 1 0-2.8 2.8L12 14.6l3.8-3.8A2 2 0 1 0 13 8z"/><path d="M4 14c2 3.5 5 5.5 8 5.5s6-2 8-5.5"/>',
  },
];
---

<section class="trust">
  <div class="container">
    <ul class="trust__grid">
      {items.map((item) => (
        <li class="trust__item">
          <span class="trust__icon" aria-hidden="true">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={item.icon}
            />
          </span>
          <p class="trust__label">{item.label}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust {
    padding-block: var(--space-5);
  }
  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-4);
    background-color: var(--color-navy-tint);
    border-radius: 16px;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }
  .trust__item:hover {
    transform: translateY(-4px);
    background-color: var(--color-navy-hover);
  }
  .trust__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--space-7); /* 64px badge */
    height: var(--space-7);
    border-radius: 50%;
    color: var(--color-white);
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }
  .trust__label {
    font-size: var(--font-size-ui);
    line-height: var(--line-height-ui);
    font-weight: var(--font-weight-medium);
    color: var(--color-white);
  }

  @media (max-width: 767.98px) {
    .trust__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
  }
</style>
