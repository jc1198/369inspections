---
/**
 * Services — section intro + a bento grid of service cards.
 * Desktop: featured "Home Inspection" card spans two rows on the left, with
 * Electrical and Plumbing stacked on the right. Mobile: horizontal scroll-snap.
 */
import ServiceCard from '../ServiceCard.astro';
import ArrowLink from '../ArrowLink.astro';

const services = [
  {
    title: 'Home Inspection',
    description:
      "A comprehensive assessment of your home's structure, systems, and components. Our most thorough service.",
    price: 'From $500 · 3 hours',
    badge: 'Most thorough',
    featured: true,
  },
  {
    title: 'Electrical Inspection',
    description:
      "A detailed evaluation of your home's electrical systems, panels, wiring, and outlets.",
    price: '$150 · 1.5 hours',
  },
  {
    title: 'Plumbing Inspection',
    description:
      'A thorough check of pipes, fixtures, water heaters, and drainage systems throughout the home.',
    price: '$150 · 1.5 hours',
  },
];
---

<section class="services" id="services">
  <div class="container">
    <div class="services__head">
      <h2 class="text-h1">Our services</h2>
      <p class="text-lead services__sub">
        From full home inspections to targeted system checks, we give you a
        clear picture of what you're buying.
      </p>
    </div>

    <ul class="services__grid">
      {services.map((service) => (
        <li class:list={['services__item', { 'services__item--featured': service.featured }]}>
          <ServiceCard {...service} />
        </li>
      ))}
    </ul>

    <div class="services__more">
      <ArrowLink href="/services">All services</ArrowLink>
    </div>
  </div>
</section>

<style>
  .services {
    padding-block: var(--space-7);
  }
  .services__head {
    max-width: 65ch;
  }
  .services__sub {
    margin-top: var(--space-3);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 1fr;
    gap: var(--space-4);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }
  /* Featured card spans both rows in the left column */
  .services__item--featured {
    grid-row: 1 / span 2;
  }

  .services__more {
    margin-top: var(--space-5);
  }

  @media (max-width: 767.98px) {
    /* Horizontal scroll-snap carousel on mobile */
    .services__grid {
      display: flex;
      grid-auto-rows: auto;
      gap: var(--space-3);
      margin-top: var(--space-5);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      /* bleed to screen edges, pad back so first/last card align to margin */
      margin-inline: calc(var(--page-margin) * -1);
      padding-inline: var(--page-margin);
      -webkit-overflow-scrolling: touch;
    }
    .services__item {
      flex: 0 0 80%;
      max-width: 320px;
      scroll-snap-align: start;
    }
    .services__item--featured {
      grid-row: auto;
    }
  }
</style>
