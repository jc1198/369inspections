---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SystemHeader from '../../components/system/SystemHeader.astro';
import Checklist from '../../components/system/Checklist.astro';
import MediaGrid from '../../components/system/MediaGrid.astro';
import RegulationsList from '../../components/system/RegulationsList.astro';
import {
  interiorRegulations,
  interiorCodeSource,
} from '../../data/interiorRegulations';

// DRAFT copy — review/replace.
const whatWeCheck = [
  'Smoke and carbon monoxide alarm placement',
  'Room sizes, ceiling heights, and egress openings',
  'Stairways, handrails, and guards',
  'Wall framing, drywall, and finishes',
  'Light, ventilation, and safety glazing',
];

// Placeholder counts — captions + real assets TBD.
const defects: string[] = Array(4).fill('');
const illustrations: string[] = Array(8).fill('');
---

<Layout title="Interior — Home Systems — 369 Home Inspections">
  <Nav />
  <main>
    <article class="detail">
      <div class="container">
        <SystemHeader
          title="Interior"
          intro="A home's interior covers the spaces you live in every day — life-safety alarms, stairs and guards, room dimensions, and finishes all factor in. Here's what we inspect and the codes behind it."
        />

        <Checklist items={whatWeCheck} />
        <MediaGrid heading="Common defects" variant="video" items={defects} />
        <MediaGrid heading="Illustrations" variant="diagram" items={illustrations} />
        <RegulationsList
          heading="Building code requirements"
          source={interiorCodeSource}
          items={interiorRegulations}
        />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .detail {
    padding-block: var(--space-6) var(--space-7);
  }
</style>
