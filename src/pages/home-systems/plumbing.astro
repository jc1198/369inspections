---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SystemHeader from '../../components/system/SystemHeader.astro';
import Checklist from '../../components/system/Checklist.astro';
import MediaGrid from '../../components/system/MediaGrid.astro';
import RegulationsList from '../../components/system/RegulationsList.astro';
import {
  plumbingRegulations,
  plumbingCodeSource,
} from '../../data/plumbingRegulations';

// DRAFT copy — review/replace.
const whatWeCheck = [
  'Fixture clearances, traps, and waste outlet sizing',
  'Shower and tub pans, drains, and slope',
  'Supply and drain pipe materials and protection',
  'Water-temperature limiting valves',
  'Access to pumps and concealed fittings',
];

// Placeholder counts — captions + real assets TBD.
const defects: string[] = Array(4).fill('');
const illustrations: string[] = Array(8).fill('');
---

<Layout title="Plumbing — Home Systems — 369 Home Inspections">
  <Nav />
  <main>
    <article class="detail">
      <div class="container">
        <SystemHeader
          title="Plumbing"
          intro="A home's plumbing moves clean water in and waste water out — fixture sizing, drainage, and temperature controls all affect safety and reliability. Here's what we inspect and the codes behind it."
        />

        <Checklist items={whatWeCheck} />
        <MediaGrid heading="Common defects" variant="video" items={defects} />
        <MediaGrid heading="Illustrations" variant="diagram" items={illustrations} />
        <RegulationsList
          heading="Building code requirements"
          source={plumbingCodeSource}
          items={plumbingRegulations}
        />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .detail {
    padding-block: var(--space-6) var(--space-7);
  }
</style>
