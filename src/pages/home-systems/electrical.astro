---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SystemHeader from '../../components/system/SystemHeader.astro';
import Checklist from '../../components/system/Checklist.astro';
import MediaGrid from '../../components/system/MediaGrid.astro';
import RegulationsList from '../../components/system/RegulationsList.astro';
import {
  electricalRegulations,
  electricalCodeSource,
} from '../../data/electricalRegulations';

// DRAFT copy — review/replace.
const whatWeCheck = [
  'Receptacle placement, spacing, and required outlet locations',
  'GFCI protection in bathrooms, kitchens, garages, and outdoors',
  'Required lighting outlets and switch locations',
  'Grounding, bonding, and raceway continuity',
  'Proper boxes and fittings for damp and wet locations',
];

// Placeholder counts — captions + real assets TBD.
const defects: string[] = Array(4).fill('');
const illustrations: string[] = Array(8).fill('');
---

<Layout title="Electrical — Home Systems — 369 Home Inspections">
  <Nav />
  <main>
    <article class="detail">
      <div class="container">
        <SystemHeader
          title="Electrical"
          intro="Your home's electrical system powers everyday life — and small wiring, grounding, or device faults can pose real safety risks. Here's what we inspect and the codes behind it."
        />

        <Checklist items={whatWeCheck} />
        <MediaGrid heading="Common defects" variant="video" items={defects} />
        <MediaGrid heading="Illustrations" variant="diagram" items={illustrations} />
        <RegulationsList
          heading="Building code requirements"
          source={electricalCodeSource}
          items={electricalRegulations}
        />
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .detail {
    padding-block: var(--space-6) var(--space-7);
  }
</style>
