---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../lib/url';

// Each home system with a themed icon (Lucide-style SVG paths).
const systems = [
  {
    name: 'Attic',
    href: '/home-systems/attic',
    // house with attic vent
    icon: '<path d="M3 12 12 4l9 8"/><path d="M5 11v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8"/><circle cx="12" cy="14.5" r="1.5"/>',
  },
  {
    name: 'Electrical',
    href: '/home-systems/electrical',
    // bolt
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  },
  {
    name: 'Exterior',
    href: '/home-systems/exterior',
    // house
    icon: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  },
  {
    name: 'Foundation',
    href: '/home-systems/foundation',
    // brick wall
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M12 3v6"/><path d="M8 9v6"/><path d="M16 9v6"/><path d="M12 15v6"/>',
  },
  {
    name: 'HVAC',
    href: '/home-systems/hvac',
    // airflow
    icon: '<path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/>',
  },
  {
    name: 'Interior',
    href: '/home-systems/interior',
    // sofa
    icon: '<path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H6v-2a2 2 0 0 0-4 0Z"/><path d="M4 18v2"/><path d="M20 18v2"/>',
  },
  {
    name: 'Plumbing',
    href: '/home-systems/plumbing',
    // water droplet
    icon: '<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>',
  },
  {
    name: 'Roof',
    href: '/home-systems/roof',
    // roof line with eaves
    icon: '<path d="M2 14 12 6l10 8"/><path d="M2 14h20"/><path d="M5 14v1.5M19 14v1.5"/>',
  },
  {
    name: 'Sewer',
    href: '/home-systems/sewer',
    // drain cover
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 3v18"/><path d="M4.5 8h15"/><path d="M4.5 16h15"/>',
  },
];
---

<Layout title="Home Systems — 369 Home Inspections">
  <Nav />
  <main>
    <section class="systems-page">
      <div class="container">
        <header class="systems-page__head">
          <h1 class="text-h1">Home systems</h1>
          <p class="text-lead systems-page__intro">
            Every home is made up of systems that work together — and each one
            tells a story about the home's condition. Explore what we inspect
            and why it matters.
          </p>
        </header>

        <ul class="systems-page__grid">
          {systems.map((system) => (
            <li class:list={['system', { 'system--link': system.href }]}>
              <span class="system__icon" aria-hidden="true">
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={system.icon}
                />
              </span>
              {system.href ? (
                <a class="system__label system__link" href={withBase(system.href)}>{system.name}</a>
              ) : (
                <span class="system__label">{system.name}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .systems-page {
    padding-block: var(--space-7);
  }
  .systems-page__head {
    max-width: 70ch;
  }
  .systems-page__intro {
    margin-top: var(--space-3);
  }

  .systems-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }

  .system {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--space-6) var(--space-4);
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .system:hover {
    transform: translateY(-4px);
    border-color: var(--color-navy);
    box-shadow: 0 8px 24px rgba(26, 26, 46, 0.08);
  }
  .system__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--space-7); /* 64px badge */
    height: var(--space-7);
    border-radius: 50%;
    color: var(--color-navy);
    background-color: var(--color-bg-subtle);
  }
  .system__label {
    font-size: var(--font-size-h3);
    line-height: var(--line-height-h3);
    font-weight: var(--font-weight-medium);
    color: var(--color-navy);
  }
  /* Linked card — make the whole card clickable via a stretched link */
  .system--link {
    position: relative;
  }
  .system__link {
    text-decoration: none;
    color: inherit;
  }
  .system__link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  @media (max-width: 767.98px) {
    .systems-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
  }
</style>
